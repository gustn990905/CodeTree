import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		
		String A = sc.next();
		
		int cnt = 0;
		
		for(int i=0; i<A.length()-1; i++) {
			if(A.charAt(i) == '(') {
				for(int j=i+1; j<A.length(); j++) {
					if(A.charAt(j) == ')') cnt++;
				}
			}
		}
		
		System.out.println(cnt);
	}
}
