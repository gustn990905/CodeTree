import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);

		int N = sc.nextInt(); 
		int[] arr = new int[N];
		
		for(int n=0; n<N; n++) {
			arr[n] = sc.nextInt();
		}
		
		int max = 1;
		int cnt = 1;
		
		for(int n=0; n<N-1; n++) {
			if(arr[n] != arr[n+1]) {
				cnt = 1;
				continue;
			}
			cnt++;
			
			max = Math.max(max, cnt);
		}
		
		System.out.println(max);
	}
}
