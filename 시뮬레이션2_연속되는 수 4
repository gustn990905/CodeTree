import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);

		int N = sc.nextInt(); 
		
		int[] arr = new int[N];
		
		for(int n=0; n<N; n++) {
			arr[n] = sc.nextInt();
		}
				
		int max = 0;
		int cnt = 0;
		
		for(int i=0; i<N; i++) {
			if(i >= 1 && arr[i] > arr[i-1]) cnt++;
			else cnt = 1;
			
			max = Math.max(max, cnt);
		}
		
		System.out.println(max);
	}
}
