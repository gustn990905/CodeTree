import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		
		int N = sc.nextInt();
		
		int[] cows = new int[N];
		
		for(int i=0; i<N; i++) {
			cows[i] = sc.nextInt();
		}
		
		int cnt = 0;
		for(int i=0; i<N-2; i++) {
			for(int j=i+1; j<N-1; j++) {
				for(int k=j+1; k<N; k++) {
					if(cows[i] <= cows[j] && cows[j] <= cows[k]) cnt++;
				}
			}
		}
		
		System.out.println(cnt);
	}
}
